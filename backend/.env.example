# Copia este archivo como .env y completa los valores

# Base de datos (SQLite para desarrollo)
DATABASE_URL=sqlite:///./miturnosalud.db

# Clave secreta para JWT - genera una con: openssl rand -hex 32
SECRET_KEY=cambia-esto-por-una-clave-segura

# Origenes permitidos para CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Cargar datos de prueba al iniciar (True en dev, False en producción)
SEED_DATA=True

# Email SMTP (dejar vacío para desactivar)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@miturnosalud.com

# Modo: clinica o veterinaria
CLINIC_TYPE=clinica
CLINIC_NAME=MiTurno Salud PRO
